---
const projects = await Astro.glob("../pages/project/*.md");
---

<h2 class="text-2xl font-bold text-slate-700" id="featured-project">
  Featured Project
</h2>
<div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
  {
    projects.map((project) => (
      <div class="group relative">
        <img src={project.frontmatter.cover} />
        <a
          aria-hidden="true"
          class="opacity-0 group-hover:opacity-100 duration-300 ease-in-out flex absolute w-full bg-black/50 h-full top-0 left-0 items-center justify-center"
          href={project.url}
        >
          <span class="text-white font-semibold px-4 py-3 rounded border border-white">
            View
          </span>
        </a>
      </div>
    ))
  }
</div>
