---
import { button_style } from "../style/button";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import empty from "../images/Empty-folder.png";
---

<Layout title="404 - Page not found!">
  <main class="container mx-auto px-4 py-10">
    <section class="flex flex-wrap items-center lg:py-20">
      <div class="w-full lg:w-1/2">
        <Image
          src={empty}
          alt="Error"
          class="w-1/2 lg:w-full mx-auto m-0"
          style="max-width:450px"
        />
      </div>
      <div class="w-full lg:w-1/2 text-center lg:text-left">
        <h1 class="mt-8 text-lg lg:text-2xl font-semibold">
          404 - Page Not Found!
        </h1>
        <div class="mt-8">
          <a href="/" class={button_style.primary}>Home</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
